generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique @db.VarChar(254)
  passwordHash        String
  firstName           String               @db.VarChar(100)
  lastName            String               @db.VarChar(100)
  phone               String?              @db.VarChar(32)
  isActive            Boolean              @default(true)
  emailVerifiedAt     DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  recordedAttendance  Attendance[]         @relation("AttendanceRecorder")
  recordedGrades      Grade[]              @relation("GradeRecorder")
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  studentProfile      Student?
  teacherProfile      Teacher?
  userRoles           UserRole[]
  verificationTokens  VerificationToken[]

  @@index([deletedAt])
  @@index([isActive])
  @@map("users")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  name        RoleName   @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  userRoles   UserRole[]

  @@index([deletedAt])
  @@map("roles")
}

model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?   @db.Uuid
  userAgent    String?   @db.VarChar(512)
  ipAddress    String?   @db.VarChar(64)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model VerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Student {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @unique @db.Uuid
  studentNumber  String       @unique @db.VarChar(32)
  dateOfBirth    DateTime?    @db.Date
  gender         Gender?
  enrollmentDate DateTime     @default(now()) @db.Date
  guardianName   String?      @db.VarChar(200)
  guardianPhone  String?      @db.VarChar(32)
  guardianEmail  String?      @db.VarChar(254)
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  attendances    Attendance[]
  enrollments    Enrollment[]
  grades         Grade[]
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@map("students")
}

model Teacher {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @db.Uuid
  employeeNumber  String    @unique @db.VarChar(32)
  hireDate        DateTime  @default(now()) @db.Date
  department      String?   @db.VarChar(100)
  qualification   String?   @db.VarChar(200)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  homeroomClasses Class[]   @relation("HomeroomTeacher")
  subjects        Subject[] @relation("SubjectTeacher")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@index([department])
  @@map("teachers")
}

model Class {
  id                String       @id @default(uuid()) @db.Uuid
  name              String       @db.VarChar(100)
  gradeLevel        Int
  academicYear      String       @db.VarChar(16)
  homeroomTeacherId String?      @db.Uuid
  capacity          Int?
  room              String?      @db.VarChar(64)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  attendances       Attendance[]
  homeroomTeacher   Teacher?     @relation("HomeroomTeacher", fields: [homeroomTeacherId], references: [id])
  enrollments       Enrollment[]

  @@unique([name, academicYear])
  @@index([deletedAt])
  @@index([academicYear])
  @@index([gradeLevel])
  @@index([homeroomTeacherId])
  @@map("classes")
}

model Subject {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique @db.VarChar(32)
  name        String    @db.VarChar(120)
  description String?
  credits     Int?
  teacherId   String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  grades      Grade[]
  teacher     Teacher?  @relation("SubjectTeacher", fields: [teacherId], references: [id])

  @@index([deletedAt])
  @@index([teacherId])
  @@map("subjects")
  attendances Attendance[]
}

model Enrollment {
  id           String           @id @default(uuid()) @db.Uuid
  studentId    String           @db.Uuid
  classId      String           @db.Uuid
  academicYear String           @db.VarChar(16)
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime         @default(now())
  withdrawnAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  class        Class            @relation(fields: [classId], references: [id])
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId, academicYear])
  @@index([classId])
  @@index([studentId])
  @@index([deletedAt])
  @@index([status])
  @@map("enrollments")
}
model Attendance {
  id           String           @id @default(uuid()) @db.Uuid
  studentId    String           @db.Uuid
  classId      String           @db.Uuid
  subjectId    String?          @db.Uuid
  date         DateTime         @db.Date
  status       AttendanceStatus
  notes        String?
  recordedById String           @db.Uuid
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  class        Class            @relation(fields: [classId], references: [id])
  subject      Subject?         @relation(fields: [subjectId], references: [id])
  recordedBy   User             @relation("AttendanceRecorder", fields: [recordedById], references: [id])
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId, subjectId, date])
  @@index([classId, date])
  @@index([subjectId, date])
  @@index([studentId, date])
  @@index([deletedAt])
  @@index([recordedById])
  @@map("attendance")
}

model Grade {
  id           String    @id @default(uuid()) @db.Uuid
  studentId    String    @db.Uuid
  subjectId    String    @db.Uuid
  type         GradeType
  term         Term
  academicYear String    @db.VarChar(16)
  score        Decimal   @db.Decimal(6, 2)
  maxScore     Decimal   @db.Decimal(6, 2)
  weight       Decimal?  @db.Decimal(4, 2)
  remarks      String?
  recordedById String    @db.Uuid
  recordedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  recordedBy   User      @relation("GradeRecorder", fields: [recordedById], references: [id])
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject   @relation(fields: [subjectId], references: [id])

  @@index([studentId, subjectId, term, academicYear])
  @@index([subjectId])
  @@index([recordedById])
  @@index([deletedAt])
  @@index([recordedAt])
  @@map("grades")
}

model IdempotencyKey {
  key            String   @id @db.VarChar(128)
  scope          String   @db.VarChar(64)
  userId         String?  @db.Uuid
  requestHash    String   @db.VarChar(128)
  responseStatus Int
  responseBody   Json?
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
  @@index([scope, userId])
  @@map("idempotency_keys")
}

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @db.Uuid
  entityType String   @db.VarChar(64)
  entityId   String   @db.Uuid
  action     String   @db.VarChar(32)
  diff       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_events")
}

enum RoleName {
  ADMIN
  TEACHER
  STUDENT
  PARENT
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
  TRANSFERRED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum GradeType {
  EXAM
  QUIZ
  HOMEWORK
  PROJECT
  PARTICIPATION
  FINAL
}

enum Term {
  TERM_1
  TERM_2
  TERM_3
  TERM_4
}
